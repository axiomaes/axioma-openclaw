# Servidor y Entorno
NODE_ENV=production
PORT=3000

# Conexión con tu IA en Cloudflare / Groq
GROQ_API_KEY=
CLOUDFLARE_AI_ENDPOINT=https://api.cloudflare.com/client/v4/accounts/TU_ACCOUNT_ID/ai/v1/chat/completions
CLOUDFLARE_AUTH_TOKEN=tu_token_de_cloudflare
CLOUDFLARE_ACCOUNT_ID=tu_account_id_de_cloudflare
OLLAMA_MODEL=qwen2.5-coder # O el modelo que tengas corriendo

# Conexión Base de Datos (Axioma Core Postgres)
DATABASE_URL=postgresql://usuario:password@axioma-postgres-host:5432/axioma_db?schema=public

# Credenciales de Redes Sociales (Para cuando configuremos las APIs)
LINKEDIN_ACCESS_TOKEN=tu_token_de_linkedin
LINKEDIN_PERSON_ID=tu_person_id_de_linkedin
INSTAGRAM_ACCESS_TOKEN=tu_token_de_instagram

# Configuración Mailcow (IMAP/SMTP)
MAILCOW_IMAP_HOST=mail.axioma-creativa.es
MAILCOW_IMAP_PORT=993
MAILCOW_SMTP_HOST=mail.axioma-creativa.es
MAILCOW_SMTP_PORT=587
MAILCOW_USER=soporte@axioma-creativa.es
MAILCOW_PASS=tu_password_segura

# Límite diario de emails procesados por mailcow-triage
EMAIL_DAILY_LIMIT=10

# Email destino para alertas del agente (SEO topics, token expirado, health check)
NOTIFY_EMAIL=ia@axioma-creativa.es

# Conexión con Axioma Core API
AXIOMA_API_URL=https://tu-backend.axioma-creativa.es
CONTROL_PLANE_TOKEN=tu_control_plane_token

# Redes Sociales adicionales
FACEBOOK_ACCESS_TOKEN=tu_token_de_facebook
FACEBOOK_PAGE_ID=tu_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=tu_business_account_id

# GitHub (para commits del SEO agent)
GITHUB_TOKEN=tu_github_token
GITHUB_REPO_OWNER=axiomaes
GITHUB_REPO_NAME=axioma-creativa-site
GITHUB_BRANCH=main
