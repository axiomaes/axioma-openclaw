# Servidor y Entorno
NODE_ENV=production
PORT=3000

# Conexión con tu IA en Cloudflare
CLOUDFLARE_AI_ENDPOINT=https://api.cloudflare.com/client/v4/accounts/TU_ACCOUNT_ID/ai/v1/chat/completions
CLOUDFLARE_AUTH_TOKEN=tu_token_de_cloudflare
CLOUDFLARE_ACCOUNT_ID=tu_account_id_de_cloudflare
OLLAMA_MODEL=qwen2.5-coder # O el modelo que tengas corriendo

# Conexión Base de Datos (Axioma Core Postgres)
DATABASE_URL=postgresql://usuario:password@axioma-postgres-host:5432/axioma_db?schema=public

# Credenciales de Redes Sociales (Para cuando configuremos las APIs)
LINKEDIN_ACCESS_TOKEN=tu_token_de_linkedin
INSTAGRAM_ACCESS_TOKEN=tu_token_de_instagram

# Configuración Mailcow (IMAP/SMTP)
MAILCOW_IMAP_HOST=mail.axioma-creativa.es
MAILCOW_IMAP_PORT=993
MAILCOW_SMTP_HOST=mail.axioma-creativa.es
MAILCOW_SMTP_PORT=465
MAILCOW_USER=soporte@axioma-creativa.es
MAILCOW_PASS=tu_password_segura
